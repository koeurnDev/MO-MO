# Telegram Bot Token (Get from @BotFather)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# PostgreSQL Connection String (e.g., from Neon.tech)
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# The HTTPS URL of your frontend (Vite app on Render or ngrok)
WEBAPP_URL=https://your-mini-app-webapp.onrender.com

# Admin User ID (Get from @userinfobot)
SUPERADMIN_ID=12345678

# Cloudinary Credentials (for product image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: Webhook URL for production (if not using long polling)
WEBHOOK_URL=https://your-mini-app-bot.onrender.com/webhook

# Port for the Express server
PORT=3000
